<% layout("/layouts/boilerplate") -%>
<body style="background: #F7F5EF;">

    <br /><br />
    
    <form method="POST" action="/listings" enctype="multipart/form-data">
      
      <div class="row">
      <div class="col-8 offset-2">
      <h3>Create a New Listing</h3>
      <br>
      <div class="form-container" >
      
      <div>
      <lable for="title" class="form-lable">Title</lable>
      <input name="listing[title]" placeholder="title" type="text" class="form-control" />
      </div>
      <br /><br />
      <div>
       <lable for="description" class="form-lable">Description</lable> 
      <textarea
        name="listing[description]"
        placeholder="enter description"
        class="form-control"
      ></textarea>
      </div>
      <br /><br />
      <div>
       <lable for="image" class="form-lable">Image Upload</lable> 
      <input
        name="listing[image]"
        type="file"
        class="form-control"
      />
      </div>
      <br /><br />
      <div class="nested-cont"
      >


      <div class="mb-3 col-md-4" >
      <lable for="price" class="form-lable">price</lable>
      <input name="listing[price]" placeholder="1000" type="number" class="form-control" />
      </div>
      <br /><br />
      <div class="mb-3 col-md-6">
      <lable for="country" class="form-lable">Country</lable>
      <input name="listing[country]" placeholder="India" type="text" class="form-control" />
      </div>


      </div>
      <br /><br />
      <lable for="location" class="form-lable">Location</lable>
      <input
        name="listing[location]"
        placeholder="Pune"
        type="text"
        class="form-control"
      />
      <br /><br />
      <button class="add-club">Add</button>
      </div>
      </div>
      </div>
    </form>
    
</body>

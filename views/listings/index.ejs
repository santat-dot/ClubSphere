<% layout('layouts/boilerplate') -%>

<div class="listing-heading">
  <h4 class="fw-bold">Discover Club Rooms</h4>
  <p class="text-muted">Browse premium spaces for your next event, workshop, or competition.</p>
</div>

<% if (allListings.length === 0) { %>
  <div class="empty-state">
    <h5>No listings matched your search.</h5>
    <p>Try a different keyword or browse all available club rooms.</p>
  </div>
<% } else { %>
  <div class="listing-grid">
    <% for (let club of allListings) { %>
      <a href="/listings/<%= club.id %>" class="listing-card-link">
        <div class="card listing-card">
          <img src="<%= club.image.url %>" class="card-img-top" alt="<%= club.title %>">
          <div class="card-img-overlay card-overlay"></div>
          <div class="card-body">
            <h5 class="card-title"><%= club.title %></h5>
            <p class="card-text">&#8377; <%= club.price.toLocaleString("en-IN") %> / team</p>
            <% if (club.location) { %>
              <p class="card-location"><%= club.location %></p>
            <% } %>
          </div>
        </div>
      </a>
    <% } %>
  </div>
<% } %>

